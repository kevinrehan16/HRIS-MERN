// prisma/schema.prisma

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Employee {
  id              Int             @id @default(autoincrement())
  employeeId      String          @unique // Halimbawa: HRIS-2024-001
  firstName       String
  lastName        String
  email           String          @unique
  password        String
  faceDescriptor  String?         @db.LongText // Dito ise-save ang 128-digit numeric array
  role            Role            @default(EMPLOYEE) // <--- System Permission
  departmentId    Int?            // <--- Pag may ID it means One-To-One Relationship
  department      Department?     @relation(fields: [departmentId], references: [id])
  positionId      Int?            // <--- Pag may ID it means One-To-One Relationship
  position        Position?       @relation(fields: [positionId], references: [id])
  attendances     Attendance[]    // <--- Pag WALANG ID it means One-To-Many Relationship
  scheduleId      Int?            // <--- Pag may ID it means One-To-One Relationship
  schedule        Schedule?       @relation(fields: [scheduleId], references: [id])
  leaveCredits    Int             @default(15)
  leaves          LeaveRequest[]  // <--- Pag WALANG ID it means One-To-Many Relationship
  basicSalary     Float           @default(0.0) // Monthly Basic Salary
  payrolls        Payroll[]       // <--- Pag WALANG ID it means One-To-Many Relationship
  status          EmployeeStatus  @default(PROBATIONARY)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  description String?
  positions Position[] // Bawat Department ay may listahan ng Positions
  employees Employee[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now()) @updatedAt
}

model Position {
  id          Int        @id @default(autoincrement())
  title       String     @unique
  description String?
  // Salary Fields
  minSalary    Decimal    @default(0.0) @db.Decimal(10, 2)
  maxSalary    Decimal    @default(0.0) @db.Decimal(10, 2)
  // Relation to Department
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])
  employees   Employee[]
  createdAt   DateTime   @default(now())
}

model Attendance {
  id               Int              @id @default(autoincrement())
  date             DateTime         @default(now()) // Para sa YYYY-MM-DD
  timeIn           DateTime         @default(now())
  timeOut          DateTime?
  status           AttendanceStatus @default(PRESENT) // PRESENT, LATE, ABSENT, ON_LEAVE
  lateMinutes      Int              @default(0)  // Para madaling i-multiply sa hourly rate
  undertimeMinutes Int              @default(0)  // Para sa deduction sa payroll
  isUndertime      Boolean          @default(false)
  overtimeMinutes  Int              @default(0)
  otStatus         OTStatus         @default(NONE) // NONE, PENDING, APPROVED, REJECTED
  remarks          String?          // Halimbawa: "Late due to traffic"
  otApprovedBy     String?
  otRemarks        String?          // Reason kung bakit ni-reject (e.g., "No work done")
  
  // Relations
  employeeId       Int
  employee         Employee         @relation(fields: [employeeId], references: [id])

  // Enterprise Rule: Isang attendance record lang per employee per day
  @@unique([employeeId, date]) 
}

model Schedule {
  id             Int        @id @default(autoincrement())
  name           String     @unique // Halimbawa: "Morning Shift", "Night Shift"
  shiftStart     String     // Format: "08:00" (HH:mm)
  shiftEnd       String     // Format: "17:00"
  gracePeriod    Int        @default(15) // Minutes bago maging "LATE"
  breakDuration  Int        @default(60) // New: Duration in minutes
  restDays       String     @default("Saturday,Sunday")
  employees      Employee[]
}

model LeaveRequest {
  id           Int         @id @default(autoincrement())
  startDate    DateTime
  endDate      DateTime
  type         LeaveType
  reason       String      @db.Text
  status       LeaveStatus @default(PENDING)
  adminRemarks String?     // Bakit na-reject? O anong bilin ng Admin?
  
  // Relations
  employeeId   Int
  employee     Employee    @relation(fields: [employeeId], references: [id])
  
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Payroll {
  id                  Int      @id @default(autoincrement())
  employeeId          Int
  employee            Employee @relation(fields: [employeeId], references: [id])
  
  periodStart         DateTime
  periodEnd           DateTime
  
  // Earnings
  basicPay            Float    // (Monthly Basic / 2) for semi-monthly
  overtimePay         Float    @default(0.0)
  
  // Deductions
  absentDeduction     Float    @default(0.0)
  lateDeduction       Float    @default(0.0)
  undertimeDeduction  Float    @default(0)
  sss                 Float    @default(0.0)
  philhealth          Float    @default(0.0)
  pagibig             Float    @default(0.0)
  withholdingTax      Float    @default(0)
  nightDiffPay        Float    @default(0)
  accrued13thMonth    Float    @default(0)
  accruedOtherBonuses Float    @default(0)
  
  netPay              Float
  status              PayrollStatus  @default(PENDING) // PENDING, PAID, VOID
  createdAt           DateTime @default(now())
}

model Holiday {
  id          Int      @id @default(autoincrement())
  date        DateTime @unique // Ang mismong petsa ng holiday
  name        String   // Halimbawa: "Christmas Day" o "Labor Day"
  type        String   @default("REGULAR") // REGULAR, SPECIAL_NON_WORKING
  createdAt   DateTime @default(now())
}

// ENUMS HERE...
enum PayrollStatus {
  PENDING
  APPROVED
  PAID
  VOID
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  ON_LEAVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum EmployeeStatus {
  REGULAR
  PROBATIONARY
  CONTRACTUAL
  TERMINATED
}

enum Role {
  ADMIN      // Pwedeng mag-CRUD ng lahat
  EMPLOYEE   // Pwedeng makita lang ang sariling data
}

enum LeaveType {
  SICK       // Sakit
  VACATION   // Bakasyon
  EMERGENCY  // Emergency
  MATERNITY  // Para sa mga nanay
  PATERNITY  // Para sa mga tatay
}

enum OTStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}